  @if(user.UserAccount.PersonalMobilePhone) {
    <div class="row align-items-center">
        <label for="Personal" class="col-3 col-form-label">Personal</label>
        <!-- <div class="col-3">Personal</div> -->
        <div class="col-auto col-form-label profile-value">
            <a href="ciscotel://{{user.UserAccount.PersonalMobilePhone | stringReplace:' ':''}}">{{user.UserAccount.PersonalMobilePhone}}
            </a>
            <span class="tooltip-text" [ngbPopover]="NoTextingPopover" #noTextingPopover="ngbPopover"
                triggers="manual" [autoClose]="'outside'" [popoverClass]="'no-texting-popover'"
                (click)="noTextingPopover.open()">(No
                Texting)</span>
            <ng-template #NoTextingPopover>
                <div class="no-texting-alert">
                    <i class="fa fa-exclamation-triangle no-texting-alert-icon" aria-hidden="true"></i>
                    <div class="no-texting-alert-content">
                        <div class="no-texting-alert-title">ALERT</div>
                        <ul class="no-texting-alert-list">
                            <li>Do not send a business text to a colleague's personal mobile phone.</li>
                            <li>For more information please review the <a target="_blank"
                                    href="https://abctestchina.sharepoint.cn/sites/howto/SitePages/Firm-Approved-Messaging-Systems-for-China-Onshore-Domain-(COD).aspx">Communications
                                    Guidance FAQs</a></li>
                        </ul>
                        <div class="no-texting-alert-actions">
                            <button type="button" class="btn btn-primary no-texting-alert-ok"
                                (click)="noTextingPopover.close()">Ok</button>
                        </div>
                    </div>
                </div>
            </ng-template>
        </div>
    </div>
    }
