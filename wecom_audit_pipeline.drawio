  <!-- ============================================================== -->
  <!-- Page 3: Reminder Flow + Daily Timeline                          -->
  <!-- ============================================================== -->
  <diagram id="reminder" name="3. Reminder + Daily Timeline">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="rt" value="Reminder Flow + Daily Cron Timeline" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- ============ Daily Timeline (top section) ============ -->
        <mxCell id="tl_title" value="One cycle-day cron timeline (suggested schedule)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="700" height="30" as="geometry" />
        </mxCell>

        <!-- Timeline backbone -->
        <mxCell id="tl_line" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#666666;strokeWidth=3;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="80" y="180" as="sourcePoint" />
            <mxPoint x="1320" y="180" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Timeline points -->
        <mxCell id="tp1" value="07:00&#10;Pre-Analysis&#10;Reminder #1&#10;(Normal)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tp2" value="07:45&#10;Pre-Analysis&#10;Reminder #2&#10;(Final)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="120" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tp3" value="08:00&#10;Phase 1&#10;ANALYSIS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="120" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tp4" value="08:10&#10;Pre-Validate&#10;Reminder #1&#10;(Normal)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="120" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tp5" value="12:00&#10;Pre-Validate&#10;Reminder #2&#10;(Normal)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="120" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tp6" value="15:30&#10;Pre-Validate&#10;Reminder #3&#10;(LastCall)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="120" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tp7" value="16:00&#10;Phase 2&#10;VALIDATE + ARCHIVE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="120" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Timeline annotations below -->
        <mxCell id="tl_note1" value="reminders check ReadyBy='Analysis' files (source CSV/xlsx)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tl_note2" value="reminders check ReadyBy='Validate' files (ops-prepped .msg reports)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="200" width="500" height="30" as="geometry" />
        </mxCell>

        <!-- ============ Reminder Flow (bottom section) ============ -->
        <mxCell id="rf_title" value="Invoke-WeComAuditOpsReminder.ps1 - Internal Flow" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="700" height="30" as="geometry" />
        </mxCell>

        <mxCell id="rs" value="START&#10;-Phase Analysis|Validate&#10;-Environment QA|PROD&#10;-Sequence '1/2' -Severity Normal|Final|LastCall&#10;[-StartDate (backfill)]  [-FailOnSendError]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="310" width="320" height="100" as="geometry" />
        </mxCell>

        <mxCell id="rcycle" value="Resolve-ScheduleCycle (from ScheduleAnchor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="440" width="320" height="40" as="geometry" />
        </mxCell>

        <mxCell id="rguard" value="Cycle-day guard:&#10;not -StartDate AND cycle.EndDate != today?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="510" width="320" height="100" as="geometry" />
        </mxCell>

        <mxCell id="rguard_skip" value="Write-Warning&#10;'today is not the cycle endDate'&#10;exit 0" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="530" width="260" height="60" as="geometry" />
        </mxCell>

        <mxCell id="rtok" value="New-AuditTokenMap -&gt; resolvedSourceFolder" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="640" width="320" height="40" as="geometry" />
        </mxCell>

        <mxCell id="rpre" value="Test-PreflightReady&#10;Analysis -&gt; SourceFolder = source / Validate -&gt; ValidationFolder = source" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="710" width="320" height="60" as="geometry" />
        </mxCell>

        <mxCell id="rready" value="AllReady?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="800" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="rready_yes" value="log SKIPPED (all ready)&#10;exit 0 (no email)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="810" width="260" height="60" as="geometry" />
        </mxCell>

        <mxCell id="rcert" value="Resolve-NotificationConfig&#10;cert available?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="910" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="rcert_skip" value="log SKIPPED (no cert)&#10;exit 0" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="920" width="260" height="60" as="geometry" />
        </mxCell>

        <mxCell id="rsend" value="Send-AuditReminderNotification&#10;&#10;  To: OpsTeam only (NO Cc)&#10;  Subject: [WeCom Audit][ENV] &lt;Severity&gt; (Seq) - Pre-&lt;Phase&gt;:&#10;            N file(s) missing (cycleEndDate)&#10;  Body: missing files + deadline (ReminderTargetTimes)&#10;  Build-AuditNotificationHtml (HTML-encoded)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="540" y="1020" width="320" height="140" as="geometry" />
        </mxCell>

        <mxCell id="rcatch" value="Send failed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="1190" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="rcatch_fail" value="catch:&#10;  log FAILED&#10;  if -FailOnSendError: exit 1&#10;  else: exit 0" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="1200" width="260" height="60" as="geometry" />
        </mxCell>

        <mxCell id="rsuc" value="log SENT&#10;exit 0" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="1200" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="rlog" value="ALL paths write a one-line audit log to:&#10;&lt;LogRoot&gt;/wecom_audit_log/reminders/reminder-yyyyMMdd-Phase-HHmm.log&#10;Action: SKIPPED | SENT | FAILED" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="1300" width="800" height="60" as="geometry" />
        </mxCell>

        <!-- Design notes -->
        <mxCell id="rnote" value="DESIGN NOTES&#10;&#10;• Independent cron - does NOT block the main scheduler cycle&#10;• Cycle-day guard prevents wrong-day pings if cron misconfigured&#10;• Reminders go to OPS team only (no CC) - they're internal nudges&#10;• Multiple reminders/day differentiated by Severity in subject&#10;  (Normal -&gt; 'Action Required', Final -&gt; 'FINAL CALL', LastCall -&gt; 'LAST CALL')&#10;• Backfill mode (-StartDate) bypasses cycle-day guard and adds [Backfill] to subject&#10;• cron path always exit 0 - never break the cycle on advisory failures&#10;• -FailOnSendError = manual/smoke testing only, surfaces failures with exit 1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="900" y="510" width="460" height="280" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="re1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="rs" target="rcycle">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="rcycle" target="rguard">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re3" value="Yes (wrong day)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=10;strokeColor=#b85450;" edge="1" parent="1" source="rguard" target="rguard_skip">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re4" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=10;strokeColor=#82b366;" edge="1" parent="1" source="rguard" target="rtok">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="rtok" target="rpre">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="rpre" target="rready">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re7" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=10;strokeColor=#82b366;" edge="1" parent="1" source="rready" target="rready_yes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re8" value="No (missing)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=10;strokeColor=#b85450;" edge="1" parent="1" source="rready" target="rcert">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re9" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=10;strokeColor=#b85450;" edge="1" parent="1" source="rcert" target="rcert_skip">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re10" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=10;strokeColor=#82b366;" edge="1" parent="1" source="rcert" target="rsend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="rsend" target="rcatch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re12" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=10;strokeColor=#b85450;" edge="1" parent="1" source="rcatch" target="rcatch_fail">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re13" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=10;strokeColor=#82b366;" edge="1" parent="1" source="rcatch" target="rsuc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

