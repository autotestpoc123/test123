  <!-- ============================================================== -->
  <!-- Page 2: Scheduler Two-Phase Flow                                -->
  <!-- ============================================================== -->
  <diagram id="sched" name="2. Scheduler Two-Phase Flow">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="2000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="t" value="Invoke-WeComAuditScheduler.ps1 - Two-Phase Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="s" value="START&#10;.\Invoke-WeComAuditScheduler.ps1&#10;[-Phase All|Analysis|Validate]&#10;[-StartDate yyyyMMdd]&#10;[-ForceCurrentRunWeeks 2|4]&#10;[-env QA|PROD]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="80" width="320" height="100" as="geometry" />
        </mxCell>

        <!-- Setup -->
        <mxCell id="setup" value="Import-Module wecom_analysis_comm.psm1 -Force&#10;Resolve-AuditConfigPath -&gt; Import-PowerShellDataFile&#10;Resolve-ScheduleCycle (anchor + today -&gt; cycle.StartDate/EndDate/CurrentRunWeeks)&#10;New-AuditTokenMap (date tokens + InputRoot + SourceFolder)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="380" y="220" width="640" height="100" as="geometry" />
        </mxCell>

        <!-- Phase decision -->
        <mxCell id="pd" value="-Phase ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="640" y="360" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- =========== PHASE 1 (Analysis) =========== -->
        <mxCell id="p1_box" value="PHASE 1 — Analysis" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;dashed=1;strokeWidth=2;fontSize=14;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="480" width="640" height="640" as="geometry" />
        </mxCell>

        <mxCell id="pre1" value="Invoke-PreflightCheck (Phase=Analysis, SourceFolder=&lt;source&gt;)&#10;  -&gt; Test-PreflightReady checks ReadyBy='Analysis' files + task inputs" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="520" width="560" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pre1d" value="All files&#10;present?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="610" width="120" height="80" as="geometry" />
        </mxCell>

        <mxCell id="pre1f" value="Send-PreflightNotification (to ops)&#10;Write-PreflightReport&#10;exit 3 (MissingInputs)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="610" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="alog" value="&amp; .\Invoke-AuditLog.ps1&#10;&#10;  Assert-TaskNameUniqueness&#10;  Assert-ConfigInputDirectories&#10;  foreach task (mail|device):&#10;    wecom_mail_analysis.ps1     -&gt; Send-Mail BU&#10;    wecom_devicelog_analysis.ps1 -&gt; Send-Mail BU&#10;    write task-summary.json&#10;  Write-RunSummaryJson + Write-LatestRunPointer" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="100" y="720" width="560" height="180" as="geometry" />
        </mxCell>

        <mxCell id="alog_exit" value="$LASTEXITCODE?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="930" width="120" height="80" as="geometry" />
        </mxCell>

        <mxCell id="alog_fail" value="exit $exitCode (1)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="930" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="alog_ok" value="Resolve-PhaseHandoff (latest-run.json -&gt; RunId)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="180" y="1040" width="400" height="50" as="geometry" />
        </mxCell>

        <!-- =========== PHASE 2 (Validate) =========== -->
        <mxCell id="p2_box" value="PHASE 2 — Validate + Archive" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;dashed=1;strokeWidth=2;fontSize=14;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="720" y="480" width="640" height="900" as="geometry" />
        </mxCell>

        <mxCell id="p2_handoff" value="If -Phase Validate (not All):&#10;  Resolve-PhaseHandoff -&gt; RunId&#10;  (throws HANDOFF_NOT_FOUND / STATUS_MISMATCH / DATE_MISMATCH)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="760" y="520" width="560" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pre2" value="Invoke-PreflightCheck (Phase=Validate, ValidationFolder=&lt;source&gt;)&#10;  -&gt; Test-PreflightReady checks ReadyBy='Validate' files (ops-prepped .msg)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="760" y="610" width="560" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pre2d" value="All files&#10;present?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="980" y="700" width="120" height="80" as="geometry" />
        </mxCell>

        <mxCell id="pre2f" value="Send-PreflightNotification&#10;exit 3" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="700" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="aval" value="&amp; .\Invoke-AuditValidate.ps1&#10;&#10;  Assert-SourceCleanupConfig (whitelist + protected roots)&#10;  Get-ExpectedBackupFiles (static + dynamic)&#10;  Test-BackupFolderContent (source-mode validation)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="760" y="810" width="560" height="100" as="geometry" />
        </mxCell>

        <mxCell id="vald" value="Validation&#10;Passed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="980" y="940" width="120" height="80" as="geometry" />
        </mxCell>

        <mxCell id="valf" value="exit 1 (ValidationFailed)&#10;Scheduler dispatches:&#10;Send-ValidationFailureNotification" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="940" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="copy" value="Get-SourceCopyTargets&#10;Copy source -&gt; backup folder (SHA256 dedup,&#10;skip if same hash already in backup)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="1050" width="560" height="70" as="geometry" />
        </mxCell>

        <mxCell id="cleand" value="SourceCleanup&#10;.Enabled?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="980" y="1150" width="120" height="80" as="geometry" />
        </mxCell>

        <mxCell id="cleanskip" value="Skip cleanup&#10;(NoOp)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="1150" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="clean" value="Invoke-SourceFileCleanup&#10;&#10;4-LAYER SAFETY:&#10;  1. Get-NormalizedFullPath&#10;  2. Test-PathWithinAllowedRoots (whitelist)&#10;  3. Reject reparse points (symlinks/junctions)&#10;  4. SHA256: source == backup &#8594; Remove" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="760" y="1260" width="560" height="120" as="geometry" />
        </mxCell>

        <mxCell id="cleand2" value="ArchiveStatus?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="980" y="1420" width="120" height="80" as="geometry" />
        </mxCell>

        <mxCell id="archf" value="exit 2 (Archive failed)&#10;Scheduler dispatches:&#10;Send-ArchiveFailureNotification" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="1420" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ok" value="exit 0&#10;(Success)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1140" y="1420" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Exit code legend -->
        <mxCell id="exleg" value="EXIT CODES (Scheduler)&#10;&#10;  0  All phases completed&#10;  1  Analysis or Validation failed&#10;  2  Archive issues (BackupFailed / CleanupAborted / CleanupPartiallyFailed)&#10;  3  Preflight missing inputs&#10;&#10;On notification failure -&gt; write&#10;runs/&lt;RunId&gt;/validation/notification-failure.json sidecar" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="1180" width="560" height="200" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="ee1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="s" target="setup">
